# ~/.config/cava/config — used by the waveform helper script.
[general]
bars = 22
framerate = 60
sleep_timer = 1

[input]
method = pulse
source = auto

[output]
method = raw
raw_target = /dev/stdout
data_format = ascii
ascii_max_range = 7
bit_format = 8bit

[smoothing]
monstercat = 1
waves = 0
noise_reduction = 0.77
