# ~/.config/hypr/hyprlock.conf — niri lock screen.
#
# GENERATED by `rice-theme` from dotfiles/rice/templates/hyprlock.conf.tmpl.
# Do not hand-edit ~/.config/hypr/hyprlock.conf — edit this template and run
# `rice-theme set <name>`. Only the accent colour is themed; the greys and the
# semantic rose are fixed.
#
# Why hyprlock and not gtklock: gtklock runs a single, blocking PAM
# conversation, so it can only do fingerprint OR password in sequence (and only
# once you engage the field). hyprlock runs PARALLEL auth — PAM password +
# fprintd fingerprint at once — so you can touch the sensor OR type, both live
# (this is what Omarchy does). hyprlock is standalone (ext-session-lock), no
# Hyprland required; niri drives it. Lock is manual-only (Mod+L) — no idle
# daemon (CLAUDE.md §6).

general {
    hide_cursor = false              # visible pointer so the power row is clickable
    ignore_empty_input = true        # Enter on an empty field does nothing
    immediate_render = true
}

# ---- Background: the pre-blurred copy of the live wallpaper -----------------
# wallpaper-init / wallpaper-next keep ~/.cache/lockscreen-bg.jpg in sync with
# the desktop (resized, blurred 0x16, darkened to 72%), so it already matches
# the translucent-system look — no extra GPU blur pass needed here.
background {
    monitor =
    path = /home/arjun/.cache/lockscreen-bg.jpg
    color = rgba(16, 16, 28, 1.0)    # fallback if the cache isn't there yet
    blur_passes = 0
}

# ---- Clock — 12-hour h:MM AM/PM (CLAUDE.md: never 24-hour) ------------------
label {
    monitor =
    text = $TIME12
    font_family = JetBrainsMono Nerd Font
    font_size = 100
    color = rgba(244, 244, 246, 1.0)
    position = 0, 150
    halign = center
    valign = center
}

# ---- Date ------------------------------------------------------------------
label {
    monitor =
    text = cmd[update:30000] date +"%A · %B %-d"
    font_family = Inter
    font_size = 19
    color = rgba(201, 201, 208, 1.0)
    position = 0, 58
    halign = center
    valign = center
}

# ---- Password pill (parallel with fingerprint) -----------------------------
input-field {
    monitor =
    size = 340, 54
    outline_thickness = 2
    rounding = 27
    dots_center = true
    dots_size = 0.26
    dots_spacing = 0.3
    outer_color = rgba(255, 255, 255, 0.12)
    inner_color = rgba(255, 255, 255, 0.08)
    font_color = rgba(244, 244, 246, 1.0)
    font_family = Inter
    fade_on_empty = false
    placeholder_text = <span foreground="##8e8e96"><i>Touch sensor or type…</i></span>
    check_color = @ACCENT_RGBA@       # accent — waiting on auth
    fail_color  = rgba(f43f5eff)      # semantic rose — wrong password
    fail_text = <span foreground="##f43f5e"><i>$FAIL ($ATTEMPTS)</i></span>
    position = 0, -40
    halign = center
    valign = center
    shadow_passes = 2
    shadow_size = 14
    shadow_color = rgba(0, 0, 0, 0.5)
}

# ---- Fingerprint status line (under the pill) ------------------------------
label {
    monitor =
    text = $FPRINTPROMPT
    font_family = Inter
    font_size = 13
    color = rgba(142, 142, 150, 1.0)
    position = 0, -100
    halign = center
    valign = center
}

# ---- Power controls (clickable) --------------------------------------------
# Plain-text buttons matching the Quickshell power flyout. The flyout (Mod+Esc)
# can't be used while locked — the ext-session-lock protocol hides every surface
# except this lock, so the overlay would draw behind it. These live on the lock
# surface itself. logind + polkit let the active session run them without a
# password, even locked (allow_active). Suspend re-shows this lock on resume.
label {
    monitor =
    text = Log Out
    font_family = Inter
    font_size = 13
    color = rgba(201, 201, 208, 1.0)
    position = -150, 70
    halign = center
    valign = bottom
    onclick = niri msg action quit --skip-confirmation
}

label {
    monitor =
    text = Sleep
    font_family = Inter
    font_size = 13
    color = rgba(201, 201, 208, 1.0)
    position = -50, 70
    halign = center
    valign = bottom
    onclick = systemctl suspend
}

label {
    monitor =
    text = Restart
    font_family = Inter
    font_size = 13
    color = rgba(201, 201, 208, 1.0)
    position = 50, 70
    halign = center
    valign = bottom
    onclick = systemctl reboot
}

label {
    monitor =
    text = Shut Down
    font_family = Inter
    font_size = 13
    color = rgba(201, 201, 208, 1.0)
    position = 150, 70
    halign = center
    valign = bottom
    onclick = systemctl poweroff
}

# ---- Parallel auth: PAM password + fprintd fingerprint ---------------------
# Password goes through /etc/pam.d/hyprlock (auth include login). The
# fingerprint runs in parallel straight to fprintd over D-Bus — no PAM
# fingerprint module needed (fprintd's verify is allow_active=yes).
auth {
    pam:enabled = true
    pam:module = hyprlock
    fingerprint:enabled = true
    fingerprint:ready_message = Touch sensor or type password
    fingerprint:present_message = Verifying…
    fingerprint:retry_delay = 250
}
